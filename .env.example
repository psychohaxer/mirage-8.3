# Port configuration
PORT_WEB=8080
PORT_PMA=8081

# Names
APP_CONTAINER_NAME=mirage_app
WEB_CONTAINER_NAME=mirage_web
DB_CONTAINER_NAME=mirage_db
PMA_CONTAINER_NAME=mirage_phpmyadmin
NETWORK_NAME=mirage_network

# Timezone configuration
TZ=UTC

# MariaDB configuration
MYSQL_DATABASE=mirage_db
MYSQL_USER=app_user
MYSQL_PASSWORD=change_me
MYSQL_ROOT_PASSWORD=change_root

# User and group IDs for file permissions
UID=1000
GID=1000

# Postgres configuration (optional service/profile)
POSTGRES_CONTAINER_NAME=mirage_postgres
POSTGRES_DB=mirage_db
POSTGRES_USER=app_user
POSTGRES_PASSWORD=change_me

# Redis configuration (optional service/profile)
REDIS_CONTAINER_NAME=mirage_redis

# phpMyAdmin configuration
PMA_HOST=db

# PMA_USER and PMA_PASSWORD default to the MariaDB credentials above but can be overridden
PMA_USER=${MYSQL_USER}
PMA_PASSWORD=${MYSQL_PASSWORD}

# phpMyAdmin blowfish secret (replace with a secure random 32+ char string)
PMA_BLOWFISH_SECRET=your_random_32_char_string_here__
